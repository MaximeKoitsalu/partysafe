# Response headers for hosts that support them (Cloudflare Pages, Netlify).
# GitHub Pages ignores this file — the <meta> CSP in index.html is the fallback
# there. frame-ancestors is header-only (browsers ignore it in <meta>), so it
# lives here to actually take effect on supporting hosts.
/*
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
